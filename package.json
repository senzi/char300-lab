{
  "name": "char300-lab",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test tests/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.ts",
    "check:version": "node scripts/check-version.mjs",
    "benchmark": "node scripts/performance-baseline.mjs",
    "generate:archives": "node scripts/generate-synthetic-archives.mjs",
    "check": "npm run check:version && npm run test && npx tsc --noEmit && npm run build"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
